# netns.cyr — per-agent network namespace management
# Ported from rust-old/src/netns.rs
#
# Creates isolated network namespaces with veth pairs for AGNOS agents.
# Shells out to `ip` (standard practice — avoids raw netlink).
# Firewall policy rendered as nftables rulesets.
#
# Requires: src/error.cyr, lib/syscalls.cyr, lib/process.cyr

# ================================================================
# Traffic direction / protocol / action constants
# ================================================================

enum TrafficDir {
    TRAFFIC_INBOUND = 1;
    TRAFFIC_OUTBOUND = 2;
}

enum NetProtocol {
    PROTO_TCP = 1;
    PROTO_UDP = 2;
    PROTO_ANY = 3;
}

enum FwAction {
    FW_ACCEPT = 1;
    FW_DROP = 2;
}

# ================================================================
# NetNamespaceConfig struct — 7 fields * 8 = 56 bytes.
# 3-arg `set_dns(c, dns_arr, dns_count)/3` keeps its name (different
# from derive's auto-generated `set_dns_arr/2` and `set_dns_count/2`)
# and delegates through the derive setters.
# ================================================================

#derive(accessors)
struct netns_config {
    name;
    agent_ip;
    host_ip;
    prefix_len;
    enable_nat;
    dns_arr;
    dns_count;
}

fn netns_config_new(name, agent_ip, host_ip, prefix_len, enable_nat): i64 {
    var c = alloc(56);
    netns_config_set_name(c, name);
    netns_config_set_agent_ip(c, agent_ip);
    netns_config_set_host_ip(c, host_ip);
    netns_config_set_prefix_len(c, prefix_len);
    netns_config_set_enable_nat(c, enable_nat);
    netns_config_set_dns_arr(c, 0);
    netns_config_set_dns_count(c, 0);
    return c;
}

fn netns_config_set_dns(c, dns_arr, dns_count): i64 {
    netns_config_set_dns_arr(c, dns_arr);
    netns_config_set_dns_count(c, dns_count);
    return 0;
}

# ================================================================
# NetNamespaceHandle struct — 4 fields * 8 = 32 bytes.
# ================================================================

#derive(accessors)
struct netns_handle { name; veth_host; veth_agent; netns_path; }

fn netns_handle_new(name, veth_host, veth_agent, netns_path): i64 {
    var h = alloc(32);
    netns_handle_set_name(h, name);
    netns_handle_set_veth_host(h, veth_host);
    netns_handle_set_veth_agent(h, veth_agent);
    netns_handle_set_netns_path(h, netns_path);
    return h;
}

# ================================================================
# FirewallRule struct — 6 fields * 8 = 48 bytes.
# ================================================================

#derive(accessors)
struct netns_fw_rule { direction; protocol; port; remote_addr; action; comment; }

fn netns_fw_rule_new(direction, protocol, port, remote_addr, action, comment): i64 {
    var r = alloc(48);
    netns_fw_rule_set_direction(r, direction);
    netns_fw_rule_set_protocol(r, protocol);
    netns_fw_rule_set_port(r, port);
    netns_fw_rule_set_remote_addr(r, remote_addr);
    netns_fw_rule_set_action(r, action);
    netns_fw_rule_set_comment(r, comment);
    return r;
}

# ================================================================
# FirewallPolicy struct — 4 fields * 8 = 32 bytes.
# Field names match 1.0 getters: `default_in`/`default_out` (not
# `default_inbound`/`default_outbound`). Field `rules_arr` dodges
# the 3-arg `netns_fw_policy_set_rules(p, rules_arr, count)/3`
# collision; the 1.0 `rules` getter and 3-arg setter stay as
# thin wrappers.
# ================================================================

#derive(accessors)
struct netns_fw_policy { default_in; default_out; rules_arr; rule_count; }

fn netns_fw_policy_new(default_in, default_out): i64 {
    var p = alloc(32);
    netns_fw_policy_set_default_in(p, default_in);
    netns_fw_policy_set_default_out(p, default_out);
    netns_fw_policy_set_rules_arr(p, 0);
    netns_fw_policy_set_rule_count(p, 0);
    return p;
}

# 1.0 API preservation
fn netns_fw_policy_rules(p): i64 { return netns_fw_policy_rules_arr(p); }
fn netns_fw_policy_set_rules(p, rules_arr, count): i64 {
    netns_fw_policy_set_rules_arr(p, rules_arr);
    netns_fw_policy_set_rule_count(p, count);
    return 0;
}

# ================================================================
# IP address generation from agent name hash
# ================================================================

# Simple hash function for agent name -> 10.100.x.{1,2}/30
fn netns_hash_name(name): i64 {
    var h = 5381;
    var i = 0;
    var len = strlen(name);
    while (i < len) {
        var c = load8(name + i);
        h = h * 33 + c;
        i = i + 1;
    }
    # Make positive
    if (h < 0) { h = 0 - h; }
    return h;
}

# Generate agent IPs. Returns a struct { host_ip, agent_ip }.
fn netns_generate_agent_ips(agent_name): i64 {
    var h = netns_hash_name(agent_name);
    var third = h % 255;

    # Build "10.100.X.1" and "10.100.X.2"
    var host_ip = alloc(16);
    var agent_ip = alloc(16);

    var prefix = "10.100.";
    memcpy(host_ip, prefix, 7);
    memcpy(agent_ip, prefix, 7);

    # Convert third octet to string
    var tbuf = alloc(4);
    var tlen = fmt_int_buf(third, tbuf);

    memcpy(host_ip + 7, tbuf, tlen);
    store8(host_ip + 7 + tlen, 46);  # '.'
    store8(host_ip + 7 + tlen + 1, 49);  # '1'
    store8(host_ip + 7 + tlen + 2, 0);

    memcpy(agent_ip + 7, tbuf, tlen);
    store8(agent_ip + 7 + tlen, 46);  # '.'
    store8(agent_ip + 7 + tlen + 1, 50);  # '2'
    store8(agent_ip + 7 + tlen + 2, 0);

    var result = alloc(16);
    store64(result, host_ip);
    store64(result + 8, agent_ip);
    return result;
}

# ================================================================
# Create convenience config for an agent
# ================================================================

fn netns_config_for_agent(name): i64 {
    var ips = netns_generate_agent_ips(name);
    var host_ip = load64(ips);
    var agent_ip = load64(ips + 8);
    return netns_config_new(name, agent_ip, host_ip, 30, 1);
}

# ================================================================
# Validate namespace config
# ================================================================

fn netns_validate_config(config): i64 {
    var name = netns_config_name(config);
    if (name == 0) { return err_invalid_argument("namespace name is null"); }
    if (strlen(name) == 0) { return err_invalid_argument("namespace name cannot be empty"); }
    if (strlen(name) > 64) { return err_invalid_argument("namespace name too long (max 64)"); }

    var aip = netns_config_agent_ip(config);
    var hip = netns_config_host_ip(config);
    if (aip == 0) { return err_invalid_argument("agent IP is null"); }
    if (hip == 0) { return err_invalid_argument("host IP is null"); }
    if (strlen(aip) == 0) { return err_invalid_argument("agent IP cannot be empty"); }
    if (strlen(hip) == 0) { return err_invalid_argument("host IP cannot be empty"); }

    var plen = netns_config_prefix_len(config);
    if (plen == 0) { return err_invalid_argument("invalid prefix length: 0"); }
    if (plen > 32) { return err_invalid_argument("invalid prefix length: > 32"); }

    return Ok(0);
}

# ================================================================
# Truncate veth name to 15 chars (Linux max)
# ================================================================

fn netns_truncate_veth(base): i64 {
    var len = strlen(base);
    if (len <= 15) {
        var out = alloc(len + 1);
        memcpy(out, base, len);
        store8(out + len, 0);
        return out;
    }
    var out = alloc(16);
    memcpy(out, base, 15);
    store8(out + 15, 0);
    return out;
}

# ================================================================
# Helper: run ip command
# ================================================================

# Run an `ip` command. `args` is a vec of cstr argv; element 0 is the
# absolute command path. exec_vec builds a NULL-terminated argv and
# execve's it directly. (The old run_capture/_exec3 path only supported
# cmd + 2 args and passed the whole argv array as a single argument, so
# `ip netns add <name>` never reached `ip`; execve also needs an absolute
# path, not a bare "ip".)
fn netns_run_ip(args): i64 {
    var rc = exec_vec(args);
    if (rc != 0) { return err_io(0, "ip command failed"); }
    return Ok(0);
}

# ================================================================
# Build a string by concatenating parts
# ================================================================

fn netns_concat2(a, b): i64 {
    var alen = strlen(a);
    var blen = strlen(b);
    var out = alloc(alen + blen + 1);
    memcpy(out, a, alen);
    memcpy(out + alen, b, blen);
    store8(out + alen + blen, 0);
    return out;
}

fn netns_concat3(a, b, c): i64 {
    var ab = netns_concat2(a, b);
    return netns_concat2(ab, c);
}

# ================================================================
# Create agent network namespace
# ================================================================

# Create a network namespace for an agent with veth pair and IP configuration.
# Returns Result: Ok(handle_ptr) or Err.
fn netns_create_agent_netns(config): i64 {
    var vres = netns_validate_config(config);
    if (is_err_result(vres) == 1) { return vres; }

    var name = netns_config_name(config);
    var ns_name = netns_concat2("agnos-agent-", name);
    var veth_host = netns_truncate_veth(netns_concat3("veth-", name, "-h"));
    var veth_agent = netns_truncate_veth(netns_concat3("veth-", name, "-a"));

    # 1. Create namespace: ip netns add <ns_name>
    var args1 = vec_new();
    vec_push(args1, "/usr/sbin/ip"); vec_push(args1, "netns");
    vec_push(args1, "add"); vec_push(args1, ns_name);
    var res = netns_run_ip(args1);
    if (is_err_result(res) == 1) { return res; }

    # 2. Create veth pair: ip link add <host> type veth peer name <agent>
    var args2 = vec_new();
    vec_push(args2, "/usr/sbin/ip"); vec_push(args2, "link"); vec_push(args2, "add");
    vec_push(args2, veth_host); vec_push(args2, "type"); vec_push(args2, "veth");
    vec_push(args2, "peer"); vec_push(args2, "name"); vec_push(args2, veth_agent);
    res = netns_run_ip(args2);
    if (is_err_result(res) == 1) {
        # Cleanup namespace
        var cleanup = vec_new();
        vec_push(cleanup, "/usr/sbin/ip"); vec_push(cleanup, "netns");
        vec_push(cleanup, "delete"); vec_push(cleanup, ns_name);
        netns_run_ip(cleanup);
        return res;
    }

    # 3. Move agent veth into namespace: ip link set <agent> netns <ns>
    var args3 = vec_new();
    vec_push(args3, "/usr/sbin/ip"); vec_push(args3, "link"); vec_push(args3, "set");
    vec_push(args3, veth_agent); vec_push(args3, "netns"); vec_push(args3, ns_name);
    res = netns_run_ip(args3);
    if (is_err_result(res) == 1) {
        # Cleanup
        var cl1 = vec_new();
        vec_push(cl1, "/usr/sbin/ip"); vec_push(cl1, "link");
        vec_push(cl1, "delete"); vec_push(cl1, veth_host);
        netns_run_ip(cl1);
        var cl2 = vec_new();
        vec_push(cl2, "/usr/sbin/ip"); vec_push(cl2, "netns");
        vec_push(cl2, "delete"); vec_push(cl2, ns_name);
        netns_run_ip(cl2);
        return res;
    }

    # 4. Assign IPs
    var plen_str = alloc(4);
    var plen_slen = fmt_int_buf(netns_config_prefix_len(config), plen_str);
    store8(plen_str + plen_slen, 0);

    var host_cidr = netns_concat3(netns_config_host_ip(config), "/", plen_str);
    var agent_cidr = netns_concat3(netns_config_agent_ip(config), "/", plen_str);

    # ip addr add <host_cidr> dev <veth_host>
    var args4 = vec_new();
    vec_push(args4, "/usr/sbin/ip"); vec_push(args4, "addr"); vec_push(args4, "add");
    vec_push(args4, host_cidr); vec_push(args4, "dev"); vec_push(args4, veth_host);
    netns_run_ip(args4);

    # ip netns exec <ns> ip addr add <agent_cidr> dev <agent>
    # (the inner `ip` is PATH-resolved by `ip netns exec`, so it stays bare)
    var args5 = vec_new();
    vec_push(args5, "/usr/sbin/ip"); vec_push(args5, "netns"); vec_push(args5, "exec"); vec_push(args5, ns_name);
    vec_push(args5, "ip"); vec_push(args5, "addr"); vec_push(args5, "add"); vec_push(args5, agent_cidr);
    vec_push(args5, "dev"); vec_push(args5, veth_agent);
    netns_run_ip(args5);

    # 5. Bring interfaces up
    var args6 = vec_new();
    vec_push(args6, "/usr/sbin/ip"); vec_push(args6, "link"); vec_push(args6, "set");
    vec_push(args6, veth_host); vec_push(args6, "up");
    netns_run_ip(args6);

    # Bring up agent side in namespace
    var args7 = vec_new();
    vec_push(args7, "/usr/sbin/ip"); vec_push(args7, "netns"); vec_push(args7, "exec"); vec_push(args7, ns_name);
    vec_push(args7, "ip"); vec_push(args7, "link"); vec_push(args7, "set"); vec_push(args7, veth_agent);
    vec_push(args7, "up");
    netns_run_ip(args7);

    # Bring up loopback in namespace
    var args8 = vec_new();
    vec_push(args8, "/usr/sbin/ip"); vec_push(args8, "netns"); vec_push(args8, "exec"); vec_push(args8, ns_name);
    vec_push(args8, "ip"); vec_push(args8, "link"); vec_push(args8, "set"); vec_push(args8, "lo");
    vec_push(args8, "up");
    netns_run_ip(args8);

    # Set default route inside namespace
    var args9 = vec_new();
    vec_push(args9, "/usr/sbin/ip"); vec_push(args9, "netns"); vec_push(args9, "exec"); vec_push(args9, ns_name);
    vec_push(args9, "ip"); vec_push(args9, "route"); vec_push(args9, "add"); vec_push(args9, "default");
    vec_push(args9, "via"); vec_push(args9, netns_config_host_ip(config));
    netns_run_ip(args9);

    # Build netns path
    var netns_path = netns_concat2("/var/run/netns/", ns_name);

    var handle = netns_handle_new(ns_name, veth_host, veth_agent, netns_path);
    return Ok(handle);
}

# ================================================================
# Destroy agent network namespace
# ================================================================

fn netns_destroy_agent_netns(handle): i64 {
    var veth_host = netns_handle_veth_host(handle);
    var ns_name = netns_handle_name(handle);

    # Delete host-side veth (peer is auto-deleted)
    var args1 = vec_new();
    vec_push(args1, "/usr/sbin/ip"); vec_push(args1, "link");
    vec_push(args1, "delete"); vec_push(args1, veth_host);
    netns_run_ip(args1);

    # Delete namespace
    var args2 = vec_new();
    vec_push(args2, "/usr/sbin/ip"); vec_push(args2, "netns");
    vec_push(args2, "delete"); vec_push(args2, ns_name);
    return netns_run_ip(args2);
}

# ================================================================
# Render nftables ruleset from FirewallPolicy
# ================================================================

# Helper to append a string to a buffer, return new position.
# Checks bounds against buf_size; if exceeded, returns pos unchanged (truncation).
fn netns_nft_append(buf, pos, str): i64 {
    var len = strlen(str);
    if (pos + len >= 16384) { return pos; }
    memcpy(buf + pos, str, len);
    return pos + len;
}

fn netns_nft_action_str(action): i64 {
    if (action == FW_ACCEPT) { return "accept"; }
    return "drop";
}

fn netns_nft_proto_str(proto): i64 {
    if (proto == PROTO_TCP) { return "tcp"; }
    if (proto == PROTO_UDP) { return "udp"; }
    return 0;
}

# Render a FirewallPolicy into an nftables ruleset string.
# Returns a heap-allocated null-terminated string.
fn netns_render_nftables_ruleset(policy): i64 {
    var buf_size = 16384;
    var buf = alloc(buf_size);
    var pos = 0;

    pos = netns_nft_append(buf, pos, "table inet kavach {\n");

    # Input chain
    pos = netns_nft_append(buf, pos, "  chain input { type filter hook input priority 0; policy ");
    pos = netns_nft_append(buf, pos, netns_nft_action_str(netns_fw_policy_default_in(policy)));
    pos = netns_nft_append(buf, pos, ";\n");
    pos = netns_nft_append(buf, pos, "    ct state established,related accept\n");
    pos = netns_nft_append(buf, pos, "    iif lo accept\n");

    var rules = netns_fw_policy_rules(policy);
    var count = netns_fw_policy_rule_count(policy);
    var i = 0;
    while (i < count) {
        var rule = load64(rules + i * 8);
        if (netns_fw_rule_direction(rule) == TRAFFIC_INBOUND) {
            var action = netns_nft_action_str(netns_fw_rule_action(rule));
            var proto = netns_nft_proto_str(netns_fw_rule_protocol(rule));
            var port = netns_fw_rule_port(rule);
            if (proto != 0) {
                if (port > 0) {
                    pos = netns_nft_append(buf, pos, "    ");
                    pos = netns_nft_append(buf, pos, proto);
                    pos = netns_nft_append(buf, pos, " dport ");
                    var pbuf = alloc(8);
                    var plen = fmt_int_buf(port, pbuf);
                    store8(pbuf + plen, 0);
                    pos = netns_nft_append(buf, pos, pbuf);
                    pos = netns_nft_append(buf, pos, " ");
                    pos = netns_nft_append(buf, pos, action);
                    pos = netns_nft_append(buf, pos, " comment \"");
                    pos = netns_nft_append(buf, pos, netns_fw_rule_comment(rule));
                    pos = netns_nft_append(buf, pos, "\"\n");
                }
            }
            var raddr = netns_fw_rule_remote_addr(rule);
            if (raddr != 0) {
                if (strlen(raddr) > 0) {
                    pos = netns_nft_append(buf, pos, "    ip saddr ");
                    pos = netns_nft_append(buf, pos, raddr);
                    pos = netns_nft_append(buf, pos, " ");
                    pos = netns_nft_append(buf, pos, action);
                    pos = netns_nft_append(buf, pos, " comment \"");
                    pos = netns_nft_append(buf, pos, netns_fw_rule_comment(rule));
                    pos = netns_nft_append(buf, pos, "\"\n");
                }
            }
        }
        i = i + 1;
    }
    pos = netns_nft_append(buf, pos, "  }\n");

    # Output chain
    pos = netns_nft_append(buf, pos, "  chain output { type filter hook output priority 0; policy ");
    pos = netns_nft_append(buf, pos, netns_nft_action_str(netns_fw_policy_default_out(policy)));
    pos = netns_nft_append(buf, pos, ";\n");
    pos = netns_nft_append(buf, pos, "    ct state established,related accept\n");
    pos = netns_nft_append(buf, pos, "    oif lo accept\n");

    i = 0;
    while (i < count) {
        var rule = load64(rules + i * 8);
        if (netns_fw_rule_direction(rule) == TRAFFIC_OUTBOUND) {
            var action = netns_nft_action_str(netns_fw_rule_action(rule));
            var proto = netns_nft_proto_str(netns_fw_rule_protocol(rule));
            var port = netns_fw_rule_port(rule);
            if (proto != 0) {
                if (port > 0) {
                    pos = netns_nft_append(buf, pos, "    ");
                    pos = netns_nft_append(buf, pos, proto);
                    pos = netns_nft_append(buf, pos, " dport ");
                    var pbuf = alloc(8);
                    var plen = fmt_int_buf(port, pbuf);
                    store8(pbuf + plen, 0);
                    pos = netns_nft_append(buf, pos, pbuf);
                    pos = netns_nft_append(buf, pos, " ");
                    pos = netns_nft_append(buf, pos, action);
                    pos = netns_nft_append(buf, pos, " comment \"");
                    pos = netns_nft_append(buf, pos, netns_fw_rule_comment(rule));
                    pos = netns_nft_append(buf, pos, "\"\n");
                }
            }
            var raddr = netns_fw_rule_remote_addr(rule);
            if (raddr != 0) {
                if (strlen(raddr) > 0) {
                    pos = netns_nft_append(buf, pos, "    ip daddr ");
                    pos = netns_nft_append(buf, pos, raddr);
                    pos = netns_nft_append(buf, pos, " ");
                    pos = netns_nft_append(buf, pos, action);
                    pos = netns_nft_append(buf, pos, " comment \"");
                    pos = netns_nft_append(buf, pos, netns_fw_rule_comment(rule));
                    pos = netns_nft_append(buf, pos, "\"\n");
                }
            }
        }
        i = i + 1;
    }
    pos = netns_nft_append(buf, pos, "  }\n");
    pos = netns_nft_append(buf, pos, "}\n");
    store8(buf + pos, 0);

    return buf;
}

# ================================================================
# Apply nftables ruleset to a namespace
# ================================================================

# Apply a pre-rendered nftables ruleset inside the namespace.
# ruleset: null-terminated nftables script string.
# Returns Result.
fn netns_apply_nftables_ruleset(handle, ruleset): i64 {
    var ns_name = netns_handle_name(handle);

    # Write ruleset to per-PID temp file
    var nft_pid = sys_getpid();
    var nft_pid_buf[24];
    var nft_pid_len = fmt_int_buf(nft_pid, &nft_pid_buf);
    var nft_prefix = "/run/agnos/nft-tmp-";
    var nft_prefix_len = strlen(nft_prefix);
    var nft_suffix = ".conf";
    var nft_suffix_len = strlen(nft_suffix);
    var tmp_path = alloc(nft_prefix_len + nft_pid_len + nft_suffix_len + 1);
    memcpy(tmp_path, nft_prefix, nft_prefix_len);
    memcpy(tmp_path + nft_prefix_len, &nft_pid_buf, nft_pid_len);
    memcpy(tmp_path + nft_prefix_len + nft_pid_len, nft_suffix, nft_suffix_len);
    store8(tmp_path + nft_prefix_len + nft_pid_len + nft_suffix_len, 0);

    # Ensure directory exists (ignore errors)
    var mkdir_args = vec_new();
    vec_push(mkdir_args, "/usr/bin/mkdir"); vec_push(mkdir_args, "-p");
    vec_push(mkdir_args, "/run/agnos");
    exec_vec(mkdir_args);

    # Write ruleset to file
    var fd = sys_open(tmp_path, 0x241, 0x1A4);  # O_WRONLY|O_CREAT|O_TRUNC, 0644
    if (fd < 0) {
        return err_io(0 - fd, "failed to create nft temp file");
    }
    var rlen = strlen(ruleset);
    sys_write(fd, ruleset, rlen);
    sys_close(fd);

    # Clean up temp file on any return path
    defer { sys_unlink(tmp_path); }

    # ip netns exec <ns> nft -f <path>
    # (the inner `nft` is PATH-resolved by `ip netns exec`, so it stays bare)
    var nft_args = vec_new();
    vec_push(nft_args, "/usr/sbin/ip"); vec_push(nft_args, "netns"); vec_push(nft_args, "exec");
    vec_push(nft_args, ns_name); vec_push(nft_args, "nft"); vec_push(nft_args, "-f");
    vec_push(nft_args, tmp_path);

    return netns_run_ip(nft_args);
}
