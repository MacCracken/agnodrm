        var k = 0;
        while (k < 10000) { update_validate_version("2025.3.1"); k = k + 1; }
        batch_record(b, now_ns() - start, 10000);
        ri = ri + 1;
    }
    bench_report(b);

    b = do_bench("compare_versions");
    ri = 0;
    while (ri < 100) {
        var start = now_ns();
        var k = 0;
        while (k < 10000) { update_compare_versions("2025.1.0", "2025.2.0"); k = k + 1; }
        batch_record(b, now_ns() - start, 10000);
        ri = ri + 1;
