# bench_all.cyr — comprehensive batch-amortized benchmarks
# 12 agnosys modules, batch timing (10K iters x 100 rounds)
#
# Build: cyrb build tests/bench_all.cyr build/bench_all
# Run:   ./build/bench_all

#define LINUX

include "lib/string.cyr"
include "lib/fmt.cyr"
include "lib/alloc.cyr"
include "lib/vec.cyr"
include "lib/str.cyr"
include "lib/tagged.cyr"
include "lib/syscalls.cyr"
include "lib/io.cyr"
include "lib/hashmap.cyr"
include "lib/process.cyr"
include "lib/fs.cyr"
include "lib/bench.cyr"

include "src/error.cyr"
include "src/util.cyr"
include "src/bootloader.cyr"
include "src/update.cyr"
include "src/fuse.cyr"
include "src/udev.cyr"

fn batch_record(b, elapsed, iters) {
    var per_op = elapsed / iters;
    store64(b + 16, load64(b + 16) + elapsed);
    store64(b + 24, load64(b + 24) + iters);
    if (per_op < load64(b + 32)) { store64(b + 32, per_op); }
    if (per_op > load64(b + 40)) { store64(b + 40, per_op); }
    return 0;
}

fn do_bench(name) { return bench_new(name); }

# ================================================================
# 2. error
# ================================================================

fn bench_errors() {
    println("-- error --");
    var b = do_bench("syserr_pack");
    var ri = 0;
    while (ri < 100) {
        var start = now_ns();
        var k = 0;
        while (k < 10000) { syserr_pack(ERR_SYSCALL_FAILED, EPERM); k = k + 1; }
        batch_record(b, now_ns() - start, 10000);
        ri = ri + 1;
    }
    bench_report(b);

    b = do_bench("from_errno_eperm");
    ri = 0;
    while (ri < 100) {
        var start = now_ns();
        var k = 0;
        while (k < 10000) { err_from_errno(EPERM); k = k + 1; }
        batch_record(b, now_ns() - start, 10000);
        ri = ri + 1;
    }
    bench_report(b);

    b = do_bench("ok_create");
    ri = 0;
    while (ri < 100) {
        var start = now_ns();
        var k = 0;
        while (k < 10000) { Ok(42); k = k + 1; }
        batch_record(b, now_ns() - start, 10000);
        ri = ri + 1;
    }
    bench_report(b);

    b = do_bench("wrap_syscall_ok");
    ri = 0;
    while (ri < 100) {
        var start = now_ns();
        var k = 0;
        while (k < 10000) { wrap_syscall(syscall(SYS_GETPID)); k = k + 1; }
        batch_record(b, now_ns() - start, 10000);
        ri = ri + 1;
    }
    bench_report(b);

    return 0;
}

# ================================================================
# 5. bootloader
# ================================================================

fn bench_bootloader() {
    println("-- bootloader --");
    var safe = "root=/dev/sda1 ro quiet splash";
    var bad = "root=/dev/sda1 init=/bin/sh";
    var textlen = strlen(safe);

    var b = do_bench("validate_cmdline_safe");
    var ri = 0;
    while (ri < 100) {
        var start = now_ns();
        var k = 0;
        while (k < 10000) { bootloader_validate_kernel_cmdline(safe); k = k + 1; }
        batch_record(b, now_ns() - start, 10000);
        ri = ri + 1;
    }
    bench_report(b);

    b = do_bench("is_dangerous_token_hit");
    ri = 0;
    while (ri < 100) {
        var start = now_ns();
        var k = 0;
        var badlen = strlen(bad);
        while (k < 10000) { bootloader_is_dangerous_token(bad, badlen, "init=/bin/sh"); k = k + 1; }
        batch_record(b, now_ns() - start, 10000);
        ri = ri + 1;
    }
    bench_report(b);

    b = do_bench("is_dangerous_token_miss");
    ri = 0;
    while (ri < 100) {
        var start = now_ns();
        var k = 0;
        while (k < 10000) { bootloader_is_dangerous_token(safe, textlen, "emergency"); k = k + 1; }
        batch_record(b, now_ns() - start, 10000);
        ri = ri + 1;
    }
    bench_report(b);

    return 0;
}

