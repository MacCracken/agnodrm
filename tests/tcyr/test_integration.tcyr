# test_integration.tcyr — integration tests for the agnodrm modules
# (device model: error/util/udev/drm + deferred: journald/netns/
# bootloader/update/fuse). The trust/security/syscall/logging modules
# moved out in the agnosys → agnodrm decomposition; their tests went
# with them.
#
# Run: cyrius test tests/test_integration.tcyr

#define LINUX

include "lib/string.cyr"
include "lib/fmt.cyr"
include "lib/alloc.cyr"
include "lib/vec.cyr"
include "lib/str.cyr"
include "lib/tagged.cyr"
include "lib/syscalls.cyr"
include "lib/io.cyr"
include "lib/hashmap.cyr"
include "lib/process.cyr"
include "lib/fs.cyr"
include "lib/ct.cyr"
include "lib/slice.cyr"
