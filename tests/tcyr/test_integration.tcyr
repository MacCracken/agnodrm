# ================================================================
# error (27 assertions)
# ================================================================

fn test_error() {
    println("-- error --");
    assert_eq(syserr_kind(syserr_pack(ERR_SYSCALL_FAILED, EPERM)), ERR_SYSCALL_FAILED, "pack_k");
    assert_eq(syserr_errno(syserr_pack(ERR_SYSCALL_FAILED, EPERM)), EPERM, "pack_e");
    assert_eq(syserr_kind(syserr_pack(ERR_IO, EIO)), ERR_IO, "pack_io_k");
    assert_eq(syserr_errno(syserr_pack(ERR_IO, EIO)), EIO, "pack_io_e");
    assert_eq(syserr_kind(syserr_pack(ERR_PERMISSION_DENIED, EACCES)), ERR_PERMISSION_DENIED, "pack_pd");
    var h = syserr_new(ERR_IO, EIO, "test");
    assert_eq(syserr_kind(h), ERR_IO, "heap_k");
    assert_eq(syserr_errno(h), EIO, "heap_e");
    assert(syserr_message(h) != 0, "heap_m");
    assert_eq(is_syscall_err(0 - 1), 1, "err_neg");
    assert_eq(is_syscall_err(0 - 999), 1, "err_neg2");
    assert_eq(is_syscall_err(0), 0, "err_zero");
    assert_eq(is_syscall_err(1), 0, "err_pos");
    assert(is_ok(wrap_syscall(42)) == 1, "wrap_ok");
    assert_eq(payload(wrap_syscall(42)), 42, "wrap_v");
    assert(is_err_result(wrap_syscall(0 - 1)) == 1, "wrap_e");
    assert(is_ok(wrap_syscall(0)) == 1, "wrap_0");
    assert(is_err_result(err_from_errno(EPERM)) == 1, "errno_perm");
    assert(is_err_result(err_from_errno(EACCES)) == 1, "errno_acces");
    assert(is_err_result(err_from_errno(EINVAL)) == 1, "errno_inval");
    assert(is_err_result(err_from_errno(ENOSYS)) == 1, "errno_nosys");
    assert(is_err_result(err_invalid_argument("x")) == 1, "eia");
    assert(is_err_result(err_permission_denied("x")) == 1, "epd");
    assert(is_err_result(err_not_supported("x")) == 1, "ens");
    assert(is_err_result(err_unknown("x")) == 1, "euk");
    assert(is_err_result(err_io(EIO, "x")) == 1, "eio");
    assert(is_err_result(err_module_not_loaded("x")) == 1, "eml");
    return 0;
}

# ================================================================
# update (15 assertions)
# ================================================================

fn test_update() {
    println("-- update --");
    assert(is_ok(update_validate_version("2025.3.1")) == 1, "v_good");
    assert(is_err_result(update_validate_version("")) == 1, "v_empty");
    assert(is_err_result(update_validate_version("bad")) == 1, "v_bad");
    assert_eq(update_compare_versions("2025.1.0", "2025.2.0"), VER_LESS, "less");
    assert_eq(update_compare_versions("2025.3.0", "2025.3.0"), VER_EQUAL, "equal");
    assert_eq(update_compare_versions("2025.3.1", "2025.3.0"), VER_GREATER, "greater");
    assert_eq(update_other_slot(SLOT_A), SLOT_B, "sl_a");
    assert_eq(update_other_slot(SLOT_B), SLOT_A, "sl_b");
    assert(streq(update_slot_str(SLOT_A), "A") == 1, "sl_sa");
    assert(streq(update_slot_str(SLOT_B), "B") == 1, "sl_sb");
    assert(streq(update_phase_str(PHASE_DOWNLOADING), "Downloading") == 1, "ph_dl");
    assert(streq(update_phase_str(PHASE_COMPLETE), "Complete") == 1, "ph_ok");
    var us = update_state_new(SLOT_A, "2026.5.1");
    update_state_set_boot_count(us, 7);
    var sb = str_builder_new();
    update_state_to_json(us, sb);
    var json = str_builder_build(sb);
    var sb_exp = str_builder_new();
    str_builder_add_cstr(sb_exp, "{\"slot\":1,\"version\":\"2026.5.1\",\"pending\":0,");
    str_builder_add_cstr(sb_exp, "\"rollback_available\":0,\"boot_count\":7}");
    assert(str_eq(json, str_builder_build(sb_exp)) == 1, "us_json");

    # Regression (1.3.0): update_check on a manifest larger than the
    # 16384-byte read buffer must not overflow. The old read loop let
    # `total` reach 16384, so the trailing `store8(buf+total,0)` wrote
    # one byte past a full buffer. Manifest is >16383 bytes with the
    # version field near the front so it still parses after truncation.
    var mpath = "/tmp/agnos-update-bigmanifest.json";
    var mbuf = alloc(20000);
    var mhdr = "{\"version\":\"9999.1.0\",\"pad\":\"";
    var mp = strlen(mhdr);
    memcpy(mbuf, mhdr, mp);
    memset(mbuf + mp, 65, 18000);  # 'A' padding past the 16KB buffer
    mp = mp + 18000;
    memcpy(mbuf + mp, "\"}", 2);
    mp = mp + 2;
    assert(file_write_all(mpath, mbuf, mp) == mp, "big_write");
    var bcfg = update_config_new();
    update_config_set_url(bcfg, "file:///tmp/agnos-update-bigmanifest.json");
    var bres = update_check(bcfg, "2026.1.0");
    assert(is_ok(bres) == 1, "big_check_ok");
    assert(payload(bres) != 0, "big_check_newer");
    sys_unlink(mpath);
    return 0;
}

# ================================================================
# bootloader (10 assertions)
# ================================================================

fn test_bootloader() {
    println("-- bootloader --");
    assert(is_ok(bootloader_validate_kernel_cmdline("root=/dev/sda1 ro")) == 1, "cmd_ok");
    assert(is_err_result(bootloader_validate_kernel_cmdline("root=/dev/sda1 init=/bin/sh")) == 1, "cmd_bad");
    assert(is_ok(bootloader_validate_kernel_cmdline("quiet splash")) == 1, "cmd_qs");
    assert(streq(bootloader_type_str(BOOT_SYSTEMD_BOOT), "systemd-boot") == 1, "bt_sd");
    assert(streq(bootloader_type_str(BOOT_GRUB2), "GRUB2") == 1, "bt_gr");
    var be = bootloader_entry_new();
    bootloader_entry_set_id(be, "arch");
    bootloader_entry_set_title(be, "Arch Linux");
    bootloader_entry_set_is_default(be, 1);
    assert(streq(bootloader_entry_id(be), "arch") == 1, "be_id");
    assert(streq(bootloader_entry_title(be), "Arch Linux") == 1, "be_t");
    assert_eq(bootloader_entry_is_default(be), 1, "be_d");
    var bc = bootloader_config_new();
    bootloader_config_set_type(bc, BOOT_SYSTEMD_BOOT);
    bootloader_config_set_timeout(bc, 5);
    assert_eq(bootloader_config_type(bc), BOOT_SYSTEMD_BOOT, "bc_t");
    assert_eq(bootloader_config_timeout(bc), 5, "bc_to");
    return 0;
}

# ================================================================
# fuse (4 assertions)
# ================================================================

fn test_fuse() {
    println("-- fuse --");
    assert_eq(fuse_starts_with("fuse.sshfs", "fuse"), 1, "f_h");
    assert_eq(fuse_starts_with("ext4", "fuse"), 0, "f_m");
    var m = fuse_mount_new("/dev/fuse", "/mnt/data", "fuse.sshfs", "rw");
    assert(streq(fuse_mount_device(m), "/dev/fuse") == 1, "fm_d");
    assert(streq(fuse_mount_mountpoint(m), "/mnt/data") == 1, "fm_m");
    # F-7 (1.1.14): /proc/mounts octal-escape unescape (\040 → space, etc.)
    var line1 = "device /mnt/with\\040space type rw 0 0";
    var f1 = fuse_extract_field(line1, strlen(line1), 1);
    assert(streq(f1, "/mnt/with space") == 1, "esc_space");
    var line2 = "src /mnt/path\\134escape ext4 rw 0 0";
    var f2 = fuse_extract_field(line2, strlen(line2), 1);
    assert(streq(f2, "/mnt/path\\escape") == 1, "esc_backslash");
    var line3 = "src /no/escape ext4 rw 0 0";
    var f3 = fuse_extract_field(line3, strlen(line3), 1);
    assert(streq(f3, "/no/escape") == 1, "esc_none");
    return 0;
}

# ================================================================
# udev (7 assertions)
# ================================================================

fn test_udev() {
    println("-- udev --");
    assert_eq(udev_parse_subsystem("block"), SUBSYS_BLOCK, "u_blk");
    assert_eq(udev_parse_subsystem("net"), SUBSYS_NET, "u_net");
    assert_eq(udev_parse_subsystem("input"), SUBSYS_INPUT, "u_inp");
    assert_eq(udev_parse_subsystem("usb"), SUBSYS_USB, "u_usb");
    assert_eq(udev_parse_subsystem("xxx"), SUBSYS_OTHER, "u_oth");
    var d = udev_devinfo_new();
    udev_devinfo_set_syspath(d, "/sys/devices/pci0");
    assert(streq(udev_devinfo_syspath(d), "/sys/devices/pci0") == 1, "ud_sp");
    udev_devinfo_set_driver(d, "e1000e");
    assert(streq(udev_devinfo_driver(d), "e1000e") == 1, "ud_dr");
    return 0;
}

# ================================================================
# drm (7 assertions)
# ================================================================

fn test_drm() {
    println("-- drm --");
    assert_eq(DRM_CAP_DUMB_BUFFER, 1, "drm_db");
    assert_eq(DRM_CAP_PRIME, 5, "drm_pr");
    var v = drm_verinfo_new(1, 2, 3, "amdgpu", "20230101", "AMD GPU");
    assert_eq(drm_verinfo_major(v), 1, "dv_ma");
    assert_eq(drm_verinfo_minor(v), 2, "dv_mi");
    assert_eq(drm_verinfo_patch(v), 3, "dv_pa");
    assert(streq(drm_verinfo_name(v), "amdgpu") == 1, "dv_n");
    assert(streq(drm_verinfo_desc(v), "AMD GPU") == 1, "dv_de");
    var sb = str_builder_new();
    drm_verinfo_to_json(v, sb);
    var json = str_builder_build(sb);
    var sb_exp = str_builder_new();
    str_builder_add_cstr(sb_exp, "{\"major\":1,\"minor\":2,\"patch\":3,");
    str_builder_add_cstr(sb_exp, "\"name\":\"amdgpu\",\"date\":\"20230101\",\"desc\":\"AMD GPU\"}");
    assert(str_eq(json, str_builder_build(sb_exp)) == 1, "dv_json");
    return 0;
}

# ================================================================
# netns (14 assertions)
# ================================================================

fn test_netns() {
    println("-- netns --");
    var c = netns_config_new("agent-1", "10.0.0.2", "10.0.0.1", 24, 1);
    assert(streq(netns_config_name(c), "agent-1") == 1, "nc_n");
    assert(streq(netns_config_agent_ip(c), "10.0.0.2") == 1, "nc_ai");
    assert_eq(netns_config_prefix_len(c), 24, "nc_pl");
    assert_eq(netns_config_enable_nat(c), 1, "nc_nat");
    var h = netns_handle_new("ns1", "veth-h", "veth-a", "/var/run/netns/ns1");
    assert(streq(netns_handle_name(h), "ns1") == 1, "nh_n");
    assert(streq(netns_handle_veth_host(h), "veth-h") == 1, "nh_vh");
    var fr = netns_fw_rule_new(TRAFFIC_INBOUND, PROTO_TCP, 443, "0.0.0.0", FW_ACCEPT, "https");
    assert_eq(netns_fw_rule_direction(fr), TRAFFIC_INBOUND, "fr_d");
    assert_eq(netns_fw_rule_protocol(fr), PROTO_TCP, "fr_p");
    assert_eq(netns_fw_rule_port(fr), 443, "fr_pt");
    assert_eq(netns_fw_rule_action(fr), FW_ACCEPT, "fr_a");
    var fp = netns_fw_policy_new(FW_DROP, FW_ACCEPT);
    assert_eq(netns_fw_policy_default_in(fp), FW_DROP, "fp_i");
    assert_eq(netns_fw_policy_default_out(fp), FW_ACCEPT, "fp_o");

    # Regression (1.3.0): netns command exec was broken — the argv array was
    # passed as a single argument to run_capture/_exec3 (cmd + 2 args max),
    # so multi-arg `ip netns add ...` never reached the binary. netns now
    # builds a cstr vec and runs it via exec_vec, which NULL-terminates a
    # real argv and execve's an absolute path. The privileged `ip` path
    # needs CAP_NET_ADMIN, so guard the mechanism netns depends on with a
    # rootless absolute-path command carrying two args past argv[0].
    var ed = "/tmp/agnos-netns-exec-test/sub";
    var margs = vec_new();
    vec_push(margs, "/usr/bin/mkdir");
    vec_push(margs, "-p");
    vec_push(margs, ed);
    exec_vec(margs);
    assert(sys_access(ed, 0) == 0, "exec_vec_multiarg");
    sys_rmdir("/tmp/agnos-netns-exec-test/sub");
    sys_rmdir("/tmp/agnos-netns-exec-test");
    return 0;
}

# ================================================================
# journald (6 assertions)
# ================================================================

fn test_journald() {
    println("-- journald --");
    var e = journald_entry_new(170000, str_from("svc"), JOURNAL_INFO, str_from("hello"), 1234);
    assert_eq(journald_entry_timestamp(e), 170000, "je_ts");
    assert_eq(journald_entry_priority(e), JOURNAL_INFO, "je_pri");
    assert_eq(journald_entry_pid(e), 1234, "je_pid");
    var f = journald_filter_new();
    journald_filter_set_unit(f, "sshd.service");
    journald_filter_set_priority(f, JOURNAL_ERR);
    journald_filter_set_lines(f, 50);
    assert(streq(journald_filter_unit(f), "sshd.service") == 1, "jf_u");
    assert_eq(journald_filter_priority(f), JOURNAL_ERR, "jf_p");
    assert_eq(journald_filter_lines(f), 50, "jf_l");
    return 0;
}

