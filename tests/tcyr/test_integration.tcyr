# Main
# ================================================================

fn main() {
    alloc_init();
    println("================================================================");
    println("  agnodrm integration tests — device model + deferred modules");
    println("================================================================");
    test_error();
    test_update();
    test_bootloader();
    bootloader_danger_reset();
    test_fuse();
    test_udev();
    test_drm();
    test_netns();
    test_journald();
    println("");
    var f = assert_summary();
    if (f > 0) { return 1; }
    return 0;
}
var r = main();
syscall(SYS_EXIT, r);
