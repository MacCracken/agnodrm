build/

# Vendored stdlib — repopulated by `cyrius deps` from the
# version-pinned snapshot in cyrius.cyml [deps] stdlib. Keeping
# this out of the repo prevents stale stubs from a prior cyrius
# version sitting in tree (matches yukti/patra convention).
/lib/

*.swp
*.swo
*~
.idea/
.vscode/
*.iml
.DS_Store
Thumbs.db
core
core.*
qemu_*.core
# bench-history.csv is tracked — the cross-version perf record.
# BENCHMARKS.md is regenerated from it by scripts/bench-history.sh (and CI), so ignore it.
BENCHMARKS.md
.claude/
.env
.env.*
rust-old/target/
